# macOS
.DS_Store
**/.DS_Store

# Build artifacts (regeneratable)
*.zip

# here.now local cache (claim tokens, slugs)
.herenow/

# Legacy original Ghost theme (kept locally for reference, not in repo)
Obras del País - Website/

# Don't ship the full image library inside the Ghost theme bundle — those should
# go to Ghost's media library. preview-site/assets/img/library/ is the canonical
# archive (mirrored here for the static preview only).
obras-del-pais-theme/assets/img/library/

# Editor / OS
.vscode/
.idea/
*.swp

# Node (in case sync script ever pulls deps)
node_modules/
npm-debug.log*

# Env (sync-videos.js reads YOUTUBE_API_KEY from process env — never commit it)
.env
.env.local
.env.*.local

# Wrangler local cache — contains Cloudflare account id + dev cache
worker/.wrangler/
**/.wrangler/
