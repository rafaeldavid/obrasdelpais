21-b608-435a1df6692c/content/images/size/w600/2022/06/DSC_9902_01edit.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/DSC_9902_01edit.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/DSC_9902_01edit.jpg 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w2400/2022/06/DSC_9902_01edit.jpg 2400w\" sizes=\"(min-width: 720px) 720px\"></div><div class=\"kg-gallery-image\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/Copy-of-DSC_0037_Momentedit.jpg\" width=\"1920\" height=\"1080\" loading=\"lazy\" alt=\"\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2022/06/Copy-of-DSC_0037_Momentedit.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/Copy-of-DSC_0037_Momentedit.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/Copy-of-DSC_0037_Momentedit.jpg 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/Copy-of-DSC_0037_Momentedit.jpg 1920w\" sizes=\"(min-width: 720px) 720px\"></div></div></div></figure><p>Cada una va acompañada de un pequeño libro que narra la <strong>historia de una mujer puertorriqueña afrodescendiente.</strong> Por ejemplo, Adolfina Villanueva, Ruth Fernandez, Ángela María Dávila, Cecilia Orta Allende, Celestina Cordero Molina, entre otras.</p><figure class=\"kg-card kg-gallery-card kg-width-wide\"><div class=\"kg-gallery-container\"><div class=\"kg-gallery-row\"><div class=\"kg-gallery-image\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/DSC_9909_01edit.jpg\" width=\"2000\" height=\"1333\" loading=\"lazy\" alt=\"\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2022/06/DSC_9909_01edit.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/DSC_9909_01edit.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/DSC_9909_01edit.jpg 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w2400/2022/06/DSC_9909_01edit.jpg 2400w\" sizes=\"(min-width: 720px) 720px\"></div><div class=\"kg-gallery-image\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/Copy-of-DSC_0044_Momentedit-1.jpg\" width=\"1920\" height=\"1080\" loading=\"lazy\" alt=\"\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2022/06/Copy-of-DSC_0044_Momentedit-1.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/Copy-of-DSC_0044_Momentedit-1.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/Copy-of-DSC_0044_Momentedit-1.jpg 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/Copy-of-DSC_0044_Momentedit-1.jpg 1920w\" sizes=\"(min-width: 720px) 720px\"></div></div></div></figure><figure class=\"kg-card kg-image-card kg-card-hascaption\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2026/03/c18d797a-06e0-551d-bf39-5350f76f6030.jpg\" class=\"kg-image\" alt=\"\" loading=\"lazy\" width=\"1133\" height=\"1700\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2026/03/c18d797a-06e0-551d-bf39-5350f76f6030.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2026/03/c18d797a-06e0-551d-bf39-5350f76f6030.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2026/03/c18d797a-06e0-551d-bf39-5350f76f6030.jpg 1133w\" sizes=\"(min-width: 720px) 720px\"><figcaption><b><strong style=\"white-space: pre-wrap;\">Vejiganta</strong></b><span style=\"white-space: pre-wrap;\"> | Muñeca inspirada en la tradición del vejigante de Loíza. Destaca el trabajo de la artesana Wilda Cruz Ortiz, especializada en máscaras elaboradas con coco como materia prima.</span></figcaption></figure><hr><figure class=\"kg-card kg-gallery-card kg-width-wide kg-card-hascaption\"><div class=\"kg-gallery-container\"><div class=\"kg-gallery-row\"><div class=\"kg-gallery-image\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/DSC_0507.JPG\" width=\"2000\" height=\"1333\" loading=\"lazy\" alt=\"\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2022/06/DSC_0507.JPG 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/DSC_0507.JPG 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/DSC_0507.JPG 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w2400/2022/06/DSC_0507.JPG 2400w\" sizes=\"(min-width: 720px) 720px\"></div><div class=\"kg-gallery-image\"><img src=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/2022/06/IMG_20220426_170430.jpg\" width=\"2000\" height=\"1500\" loading=\"lazy\" alt=\"\" srcset=\"https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w600/2022/06/IMG_20220426_170430.jpg 600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1000/2022/06/IMG_20220426_170430.jpg 1000w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w1600/2022/06/IMG_20220426_170430.jpg 1600w, https://storage.ghost.io/c/0b/21/0b211f14-b12e-4e21-b608-435a1df6692c/content/images/size/w2400/2022/06/IMG_20220426_170430.jpg 2400w\" sizes=\"(min-width: 720px) 720px\"></div></div></div><figcaption><p><span style=\"white-space: pre-wrap;\">Tras las cámaras</span></p></figcaption></figure><h2 id=\"hay-historias-que-si-no-las-contamos-se-perder%C3%A1n-para-siempre\">Hay historias que, si no las contamos, se perderán para siempre...</h2><div class=\"kg-card kg-callout-card kg-callout-card-yellow\"><div class=\"kg-callout-emoji\">🤝</div><div class=\"kg-callout-text\">Obras del País es reconocida por el IRS como una entidad sin fines de lucro calificada bajo la Sección<b><strong style=\"white-space: pre-wrap;\"> 501(c)(3)</strong></b>&nbsp;federal y&nbsp;<b><strong style=\"white-space: pre-wrap;\">1101.01 </strong></b>de PR. Esto significa que, a medida permitida por la ley, puedes restar tu donativo del ingreso bruto ajustado a la hora de presentar tu declaración de impuestos.<br><br>Los documentales van dirigidos a la preservación de nuestra herencia cultural y a la integración de la comunidad artesanal al mundo digital y educativo. Brindamos este servicio gratuitamente a los artesanos entrevistados. Tu donación permite la continuidad del proceso de coordinación, grabación, edición y publicidad de estos documentales, así como el acceso público a un archivo audiovisual del patrimonio artesanal de Puerto Rico.</div></div><hr><p><strong>¿Te quedaste con ganas de más?</strong>&nbsp;Síguenos en&nbsp;<strong>Instagram</strong>&nbsp;(<a href=\"https://instagram.com/obrasdelpais?utm_medium=copy_link&ref=obrasdelpais.com\">obrasdelpais</a>) y&nbsp;<strong>Facebook</strong>&nbsp;(<a href=\"https://www.facebook.com/obrasdelpais/\">Obras del País</a>) para contenido adicional de cada artesano.&nbsp;<strong>Y si te gustó el corto documental, coméntalo y compártelo.</strong>&nbsp;Queremos saber qué opinan. 🤗✨</p>\n\t\t</div>\n\t\t<div>\n</di