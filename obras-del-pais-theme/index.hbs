{{!< default}}

<section class="page-intro">
  <div class="page-intro__wrap">
    <span class="page-intro__crumb" data-lang="es">Detrás del archivo</span>
    <span class="page-intro__crumb" data-lang="en">Behind the archive</span>
    <h1 class="page-intro__title" data-lang="es">Noticias &amp; eventos</h1>
    <h1 class="page-intro__title" data-lang="en">Stories &amp; events</h1>
    <p class="page-intro__lede" data-lang="es">Estrenos, talleres, proyecciones, viajes de campo, y la cocina detrás de cada documental.</p>
    <p class="page-intro__lede" data-lang="en">Premieres, workshops, screenings, field trips, and the kitchen behind every documentary.</p>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="grid grid--2">
      {{#foreach posts}}
        <a class="artisan-card reveal" href="{{url}}">
          <div class="artisan-card__photo">
            <span class="artisan-card__no">{{date published_at format="MMM YYYY"}}</span>
            {{#if feature_image}}
              <img src="{{img_url feature_image size="md"}}" alt="" loading="lazy">
            {{else}}
              <div class="ph"></div>
            {{/if}}
          </div>
          <div class="artisan-card__body">
            {{#if primary_tag}}<span class="eyebrow">{{primary_tag.name}}</span>{{/if}}
            <h3 class="artisan-card__name mt-5">{{title}}</h3>
            <p class="muted">{{excerpt words="24"}}</p>
          </div>
        </a>
      {{/foreach}}
    </div>

    {{pagination}}
  </div>
</section>

{{> "newsletter"}}
