{{!< default}}

<section class="page-intro">
  <div class="page-intro__wrap">
    <span class="page-intro__crumb" data-lang="es">Recursos</span>
    <span class="page-intro__crumb" data-lang="en">Resources</span>
    <h1 class="page-intro__title" data-lang="es">Preguntas frecuentes &amp; guías</h1>
    <h1 class="page-intro__title" data-lang="en">FAQ &amp; guides</h1>
    <p class="page-intro__lede" data-lang="es">Una biblioteca de guías descargables en PDF — para educadores, comunidades, padrinos, y cualquier persona que quiera trabajar con artesanos.</p>
    <p class="page-intro__lede" data-lang="en">A library of downloadable PDF guides — for educators, communities, sponsoring members, and anyone who wants to work with artisans.</p>
  </div>
</section>

<section class="section">
  <div class="wrap">
    {{#if content}}
      <div class="prose">{{content}}</div>
    {{else}}
      <p class="muted" data-lang="es">Sube tus PDFs como páginas o posts con la etiqueta <code>guia</code> y aparecerán automáticamente.</p>
      <p class="muted" data-lang="en">Upload PDFs as pages or posts tagged <code>guia</code> and they'll appear here automatically.</p>
    {{/if}}

    {{#get "posts" filter="tag:guia" limit="all" as |guides|}}
      {{#if guides}}
        <div class="grid grid--3 mt-6">
          {{#foreach guides}}
            <a class="artisan-card" href="{{url}}">
              <div class="artisan-card__photo"><span class="artisan-card__no">PDF · {{counter}}</span>{{#if feature_image}}<img src="{{img_url feature_image size="md"}}" alt="">{{else}}<div class="ph"></div>{{/if}}</div>
              <div class="artisan-card__body"><h3 class="artisan-card__name">{{title}}</h3><p class="muted">{{excerpt words="20"}}</p></div>
            </a>
          {{/foreach}}
        </div>
      {{/if}}
    {{/get}}
  </div>
</section>
