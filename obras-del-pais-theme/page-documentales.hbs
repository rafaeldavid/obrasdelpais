{{!< default}}

<section class="page-intro">
  <div class="page-intro__wrap">
    <span class="page-intro__crumb">Galería · 2021–{{date format="YYYY"}}</span>
    <h1 class="page-intro__title" data-lang="es">Documentales</h1>
    <h1 class="page-intro__title" data-lang="en">Documentaries</h1>
    <p class="page-intro__lede" data-lang="es">38 micro-documentales filmados en 29 municipios. Cada uno gratuito, archivado para siempre, y enlazado directamente al canal de YouTube. Selección editorial mensual — no algoritmo.</p>
    <p class="page-intro__lede" data-lang="en">38 micro-documentaries filmed across 29 municipalities. Each one free, archived forever, and linked directly to YouTube. Monthly editorial selection — no algorithm.</p>
  </div>
</section>

<section class="section section--paper-warm section--tight">
  <div class="wrap">
    <span class="eyebrow" data-lang="es">Filtrar por región</span>
    <span class="eyebrow" data-lang="en">Filter by region</span>
    <div class="region-map mt-5">
      <button class="region-pill" data-region-pill="">Toda la isla</button>
      <button class="region-pill" data-region-pill="metro">Metro</button>
      <button class="region-pill" data-region-pill="norte">Norte</button>
      <button class="region-pill" data-region-pill="sur">Sur</button>
      <button class="region-pill" data-region-pill="centro">Centro</button>
      <button class="region-pill" data-region-pill="oeste">Oeste</button>
      <button class="region-pill" data-region-pill="suroeste">Suroeste</button>
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div data-docs-list></div>
  </div>
</section>

{{> "closing-line"}}
{{> "donate-cta"}}
