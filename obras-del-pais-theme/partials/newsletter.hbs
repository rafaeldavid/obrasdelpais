<section class="newsletter" id="newsletter">
  <div class="newsletter__inner">
    <p class="eyebrow" data-lang="es">Boletín</p>
    <p class="eyebrow" data-lang="en">Newsletter</p>
    <h2 class="h3 mt-5" data-lang="es">Recibe cada documental cuando se publica.</h2>
    <h2 class="h3 mt-5" data-lang="en">Get each documentary the day it publishes.</h2>
    <p class="muted mt-5" data-lang="es">Una historia al mes, sin spam, en español o inglés.</p>
    <p class="muted mt-5" data-lang="en">One story a month. No spam. Spanish or English.</p>
    <form class="newsletter__form" data-members-form="subscribe">
      <input class="newsletter__input" data-members-email type="email" required placeholder="email@ejemplo.com" aria-label="Email">
      <button class="btn btn--solid" type="submit"><span data-lang="es">Suscribirme</span><span data-lang="en">Subscribe</span></button>
    </form>
  </div>
</section>
