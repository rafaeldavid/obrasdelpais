{{!< default}}

<section style="background:#000;color:var(--paper);min-height:100vh;display:grid;place-items:center;text-align:center;padding:2rem;">
  <div>
    <p class="script" style="font-size:5rem;color:var(--ochre-soft);">{{statusCode}}</p>
    <h1 class="display" style="font-size:var(--fs-2xl);max-width:24ch;margin:1rem auto;">{{#match statusCode "404"}}Esta historia aún no se ha contado.{{else}}Algo se quedó en el taller.{{/match}}</h1>
    <p style="opacity:0.7;max-width:38ch;margin:0 auto 2rem;">{{message}}</p>
    <a class="btn btn--ghost" href="{{@site.url}}/" style="color:var(--paper);border-color:var(--paper);">← Volver al inicio</a>
  </div>
</section>
